{
  "realm": "BookStoreRealm",
  "enabled": true,
  "displayName": "BookStore Realm",

  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,

  "roles": {
    "realm": [
      { "name": "admin" },
      { "name": "user" }
    ]
  },

  "users": [
    {
      "username": "hoang",
      "enabled": true,
      "email": "hoang@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "123456",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    }
  ],

  "clients": [
    {
      "clientId": "bookstore-client",
      "name": "BookStore Client",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5173/",
        "http://localhost:5174/*",
        "http://localhost:5174/",
        "http://localhost:5000/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5174",
        "http://localhost:5000"
      ]
    }
  ]
}